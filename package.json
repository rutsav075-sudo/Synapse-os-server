{
  "name": "synapse-server",
  "version": "1.0.0",
  "description": "Synapse OS backend server based on n8n",
  "main": "index.js",
  "scripts": {
    "start": "export N8N_PORT=${PORT:-5678} && export N8N_LISTEN_ADDRESS=0.0.0.0 && n8n",
